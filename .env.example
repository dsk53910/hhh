# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_telegram_user_id_here

# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/hhh_bot

# HH.ru Configuration
HH_API_KEY=your_hh_api_key_if_available
SEARCH_INTERVAL=300
MAX_REQUESTS_PER_HOUR=100

# Auto-apply Configuration
AUTO_APPLY_ENABLED=false
REQUIRE_APPROVAL=true
MAX_APPLICATIONS_PER_DAY=5

# Notifications Configuration
NOTIFICATIONS_ENABLED=true
DIGEST_TIME=09:00
NEW_JOB_ALERT=true
APPLICATION_UPDATE=true

# Development/Production
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Optional: OpenAI for AI-powered responses
OPENAI_API_KEY=your_openai_api_key_if_using_ai_features

# Optional: Proxy configuration if needed
HTTP_PROXY=
HTTPS_PROXY=

# Security
SECRET_KEY=your_secret_key_for_session_encryption